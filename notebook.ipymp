   "source": [
    "# Load model\n",
    "loaded_model = joblib.load(\"robot_fk_model.pkl\")\n",
    "\n",
    "# Test on new input\n",
    "test_angles = np.array([[0.5, -0.3]])\n",
    "\n",
    "predicted_position = loaded_model.predict(test_angles)\n",
    "\n",
    "print(\"Predicted (x, y):\", predicted_position)\n",
    "\n",
    "# Compare with ground truth\n",
    "true_x, true_y = forward_kinematics(0.5, -0.3)\n",
    "print(\"True (x, y):\", (true_x, true_y))"
   ]
  }
